{
  "protocolVersion": 1,
  "label": "timelyLotteryV1",
  "documents": {
    "lottery": {
      "type": "object",
      "properties": {
        "lotteryId":        { "type": "string",  "maxLength": 32,  "position": 0 },
        "title":            { "type": "string",  "maxLength": 100, "position": 1 },
        "description":      { "type": "string",  "maxLength": 500, "position": 2 },
        "status":           { "type": "string",  "enum": ["active", "ended"], "maxLength": 10, "position": 3 },
        "startTime":        { "type": "integer",                   "position": 4 },
        "endTime":          { "type": "integer",                   "position": 5 },
        "durationMinutes":  { "type": "integer",                   "position": 6 },
        "totalDash":        { "type": "number",                    "position": 7 },
        "totalTickets":     { "type": "integer",                   "position": 8 },
        "participantCount": { "type": "integer",                   "position": 9 },
        "dashAddress":      { "type": "string",  "maxLength": 64,  "position": 10 },
        "autoStarted":      { "type": "boolean",                   "position": 11 }
      },
      "required": ["lotteryId", "title", "status", "startTime", "endTime", "dashAddress"],
      "additionalProperties": false,
      "indices": [
        { "name": "byLotteryId", "properties": [{ "lotteryId": "asc" }], "unique": true },
        { "name": "byStatus",    "properties": [{ "status": "asc" }] },
        { "name": "byStartTime", "properties": [{ "startTime": "asc" }] }
      ]
    },
    "result": {
      "type": "object",
      "properties": {
        "lotteryId":    { "type": "string", "maxLength": 32,  "position": 0 },
        "winnerId":     { "type": "string", "maxLength": 128, "position": 1 },
        "winnerName":   { "type": "string", "maxLength": 63,  "position": 2 },
        "winnerDash":   { "type": "number",                   "position": 3 },
        "winnerTxId":   { "type": "string", "maxLength": 128, "position": 4 },
        "reserveDash":  { "type": "number",                   "position": 5 },
        "totalDash":    { "type": "number",                   "position": 6 },
        "endTime":      { "type": "integer",                  "position": 7 },
        "initiumTitle": { "type": "string", "maxLength": 200, "position": 8 }
      },
      "required": ["lotteryId", "winnerId", "winnerDash", "endTime"],
      "additionalProperties": false,
      "indices": [
        { "name": "byLotteryId", "properties": [{ "lotteryId": "asc" }], "unique": true },
        { "name": "byWinnerName","properties": [{ "winnerName": "asc" }] }
      ]
    },
    "entry": {
      "type": "object",
      "properties": {
        "lotteryId":       { "type": "string", "maxLength": 32,  "position": 0 },
        "entryId":         { "type": "string", "maxLength": 32,  "position": 1 },
        "dpnsName":        { "type": "string", "maxLength": 64,  "position": 2 },
        "dashContributed": { "type": "number",                   "position": 3 },
        "totalTickets":    { "type": "integer",                  "position": 4 },
        "initiumTitle":    { "type": "string", "maxLength": 200, "position": 5 },
        "timestamp":       { "type": "integer",                  "position": 6 }
      },
      "required": ["lotteryId", "entryId", "dashContributed", "timestamp"],
      "additionalProperties": false,
      "indices": [
        { "name": "byEntry", "properties": [{ "lotteryId": "asc" }, { "entryId": "asc" }], "unique": true }
      ]
    },
    "word": {
      "type": "object",
      "properties": {
        "lotteryId":   { "type": "string", "maxLength": 32, "position": 0 },
        "word":        { "type": "string", "maxLength": 50, "position": 1 },
        "submittedBy": { "type": "string", "maxLength": 63, "position": 2 },
        "dummy":       { "type": "string", "maxLength": 1,  "position": 3 }
      },
      "required": ["lotteryId", "word"],
      "additionalProperties": false,
      "indices": [
        { "name": "byLotteryId", "properties": [{ "lotteryId": "asc" }] }
      ]
    },
    "initium": {
      "type": "object",
      "properties": {
        "initiumId":       { "type": "string",  "maxLength": 36,   "position": 0 },
        "slug":            { "type": "string",  "maxLength": 63,   "position": 1 },
        "title":           { "type": "string",  "maxLength": 200,  "position": 2 },
        "description":     { "type": "string",  "maxLength": 5000, "position": 3 },
        "url":             { "type": "string",  "maxLength": 1024, "position": 4 },
        "ownerDpns":       { "type": "string",  "maxLength": 63,   "position": 5 },
        "timesUsed":       { "type": "integer",                    "position": 6 },
        "totalDashEarned": { "type": "number",                     "position": 7 },
        "createdAt":       { "type": "integer",                    "position": 8 }
      },
      "required": ["initiumId", "slug", "title", "createdAt"],
      "additionalProperties": false,
      "indices": [
        { "name": "bySlug",      "properties": [{ "slug": "asc" }], "unique": true },
        { "name": "byOwner",     "properties": [{ "ownerDpns": "asc" }] },
        { "name": "byCreatedAt", "properties": [{ "createdAt": "asc" }] }
      ]
    }
  }
}
