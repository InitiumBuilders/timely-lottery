# ─── Timely.Works Environment Variables ──────────────────────────────────────
# Copy this file to .env.local for local development
# NEVER commit .env or .env.local to git
# NEVER put real secrets in this file — use placeholders only

# ── Database (SQLite) ─────────────────────────────────────────────────────────
# Local dev: use a relative path
DATABASE_URL="file:./dev-data/timely.db"
# VPS production: absolute path on your server (set in .env.local only)
# DATABASE_URL="file:/path/to/your/timely-lottery-data/timely.db"

# ── Lottery Data Directory ────────────────────────────────────────────────────
# Where store.json, uploads/, and timely.db live
# Default if not set: ./dev-data
LOTTERY_DATA_DIR="./dev-data"

# ── DASH Wallet ───────────────────────────────────────────────────────────────
# ⚠️  WARNING: This mnemonic controls the payout wallet — real funds live here
# ⚠️  NEVER commit your real mnemonic to git — ever
# ⚠️  ONLY set this on the VPS in .env.local — never on Vercel
# Generate a fresh testnet wallet for local dev:
#   node -e "const { Mnemonic } = require('@dashevo/dashcore-lib'); console.log(new Mnemonic().toString())"
DASH_MNEMONIC="your twelve word bip39 mnemonic phrase goes here"

# ── Dash Platform Identity ────────────────────────────────────────────────────
# Your Dash Platform identity ID (created via register.mjs or Dash wallet)
DASH_IDENTITY_ID="your-platform-identity-id-here"

# ── Timely.Works Data Contract ────────────────────────────────────────────────
# Assigned after running: node platform/contracts/register.mjs
# Leave blank until you've registered the contract on mainnet
TIMELY_CONTRACT_ID=""

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Set a strong, unique password — do not use the default
ADMIN_PASSWORD="choose-a-strong-unique-password"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave blank for local dev — verification links will be logged to console
RESEND_API_KEY=""
FROM_EMAIL="Timely.Works <noreply@your-verified-domain.com>"

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Production:
# NEXT_PUBLIC_SITE_URL="https://www.timely.works"

# ── Vercel → VPS Proxy ────────────────────────────────────────────────────────
# Only needed when running on Vercel (process.env.VERCEL === '1')
# Point this to your VPS with a hostname (not raw IP — Vercel edge blocks raw IPs)
# Example: http://your-server-ip.sslip.io:3000
VPS_URL="http://your-vps-hostname-or-sslip-url:3000"
# VERCEL is set automatically by Vercel platform — don't set it manually
